# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
# For macOS with Homebrew PostgreSQL (no password)
DATABASE_URL=postgres://nagorik@localhost:5432/personal_assistant
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nagorik
DB_PASSWORD=
DB_NAME=personal_assistant

# For standard PostgreSQL with password:
# DATABASE_URL=postgres://postgres:password@localhost:5432/personal_assistant

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRATION=7d

# Environment
LOG_LEVEL=debug
